# ========================================
# SARIGR – GIT IGNORE
# Protects compiled binaries, vault files,
# IDE cruft, and system garbage.
# ========================================

# --- Compiled Binaries ---
sarig
sarig.exe
*.out
*.o
*.obj
*.exe
*.dll
*.so
*.dylib

# --- Build Directories ---
build/
bin/
obj/
lib/
.deps/
__pycache__/

# --- Khuti Vault Files (CRITICAL) ---
*.khuti
*.khuti.bak
*.wallet
*.vault
*.encrypted

# --- IDE & Editor Files ---
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
*.log
.DS_Store
Thumbs.db

# --- Temporary & System Files ---
*.tmp
*.temp
*.core
*.pid
*.lock
*.cache

# --- Backup Copies ---
*.backup
*.old
*.orig

# --- Compiler Dependencies (if using CMake) ---
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake

# --- GitHub / Cloud ---
.gitattributes
.github/
.gitmodules

# --- No accidental uploads of sensitive data ---
*.pem
*.key
*.crt
*.pub
*.priv
